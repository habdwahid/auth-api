{
    "env": {
        "browser": true,
        "commonjs": true,
        "es2021": true,
        "node": true,
        "jest": true
    },
    "extends": "airbnb-base",
    "overrides": [],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "linebreak-style": "off",
        "max-len": [
            "error",
            {
                "code": 100,
                "ignoreStrings": true
            }
        ],
        "no-console": "off",
        "no-underscore-dangle": "off",
        "semi": "off"
    }
}